{
  "agent": {
    "name": "AI x Creative Production Intelligence Agent",
    "posts_per_day": 10,
    "dedup_window_days": 30
  },
  "domains": [
    {"id":"ui_ux_design","label":"UI/UX & Product Design","emoji":"🎨"},
    {"id":"3d_rendering","label":"3D Rendering & Generation","emoji":"🧊"},
    {"id":"film_video","label":"Film & AI Video Editing","emoji":"🎬"},
    {"id":"motion_design","label":"Motion Design & Animation","emoji":"✨"}
