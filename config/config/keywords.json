        "motion design AI After Effects Rive animation workflow min_faves:50"
      ],
      "filters": {"min_likes":50,"days_back":3},
      "max_per_query": 15
    },
    "linkedin": {
      "queries": [
        "AI design workflow Figma prototype",
        "AI 3D Blender ComfyUI workflow",
        "AI video editing cinematic production",
        "motion design AI animation workflow"
      ],
      "filters": {"min_likes":50,"days_back":3},
      "max_per_query": 10
